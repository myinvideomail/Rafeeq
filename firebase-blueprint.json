{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "subscription": { "type": "string", "enum": ["free", "premium"] },
        "subscriptionExpiry": { "type": "string", "format": "date-time" },
        "aiTone": { "type": "string", "enum": ["empathetic", "direct", "casual"], "description": "Preferred AI tone" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "subscription", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message between user and Rafiq",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "content", "timestamp"]
    },
    "MoodEntry": {
      "title": "MoodEntry",
      "description": "A user's mood log",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mood": { "type": "string" },
        "note": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mood", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Chat messages"
    },
    "moods/{moodId}": {
      "schema": { "$ref": "#/entities/MoodEntry" },
      "description": "Mood tracking entries"
    }
  }
}
